{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fusenchat",
  "version": "0.1.0",
  "identifier": "com.fusenchat.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "fusenchat",
        "width": 720,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
